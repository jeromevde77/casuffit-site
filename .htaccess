# ═══════════════════════════════════════════════════════════════════════
#  .htaccess — ça suffit ! ASBL  (UN SEUL fichier à la racine)
# ═══════════════════════════════════════════════════════════════════════

# ── Interdire le listing de TOUS les dossiers ─────────────────────────
Options -Indexes

# ── Encodage ──────────────────────────────────────────────────────────
AddDefaultCharset UTF-8

# Bloquer les fichiers d'installation sensibles
<FilesMatch "^(install_admin|setup|install)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^(config\.php|README\.md|INSTALL\.md|LIRE_MOI_UPLOAD\.txt|\.env|.*\.bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>
# Tous les fichiers .sql sont bloqués
<FilesMatch "\.sql$">
    Order allow,deny
    Deny from all
</FilesMatch>
# Bloquer les fichiers de migration / injection PHP
<FilesMatch "^(migrate_.*|inject_.*|update_.*|fix_.*|debug.*|test_.*)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Dossiers sensibles — accès direct interdit ────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquer UNIQUEMENT les requêtes HTTP directes (pas les include PHP internes)
    # %{REQUEST_FILENAME} = fichier demandé directement par le navigateur
    # ── cron/ : bloquer sauf ebbr_tracks.php ─────────────────────────────
    RewriteRule ^cron/ebbr_tracks\.php$ - [L]

    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^cron/(.*)$      - [F,L]

    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^lib/(.*)$       - [F,L]

    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^templates/(.*)$ - [F,L]

    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^includes/(.*)$  - [F,L]

    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^logs/(.*)$      - [F,L]

    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^uploads/(.*)$   - [F,L]

    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^cache/(.*)$     - [F,L]

    # Médias : autoriser uniquement les images
    RewriteRule ^medias/.*\.(php|sql|htaccess|env|sh)$ - [F,L]

    # ── Sitemap XML dynamique ─────────────────────────────────────────
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # ── Page d'atterrissage flyers (URL courte mémorable) ─────────────
    RewriteRule ^agir/?$      agir.php [L,QSA]
    RewriteRule ^doe-mee/?$   agir.php?lang=nl [L,QSA]
    RewriteRule ^don/?$       don.php [L,QSA]
    RewriteRule ^soutenir/?$  don.php [L,QSA]
    RewriteRule ^steunen/?$   don.php?lang=nl [L,QSA]

    # ── Multilingue : /nl/... → index.php?lang=nl&... ─────────────────
    # /nl/         → /index.php?lang=nl
    # /nl          → /index.php?lang=nl
    # /nl/?page=X  → /index.php?lang=nl&page=X  (le QSA garde les autres params)
    RewriteRule ^nl/?$           index.php?lang=nl [L,QSA]
    # /nl/<chemin> → /<chemin>?lang=nl  (les autres routes : api, admin, wind, etc.)
    RewriteRule ^nl/(.+)$        $1?lang=nl [L,QSA]
</IfModule>

# ── En-têtes de sécurité ─────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "same-origin"
    Header always set Permissions-Policy "geolocation=(self), microphone=(), camera=()"
    # Strict-Transport-Security : forcer HTTPS pendant 1 an
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://api.brevo.com https://api.open-meteo.com https://aviationweather.gov https://www.batc.be https://nominatim.openstreetmap.org; frame-src 'none'; object-src 'none'"
    # Cookies de session sécurisés
    Header always edit Set-Cookie ^(.*)$ "$1; Secure; SameSite=Lax"
</IfModule>

# ── Cache ressources statiques ────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg     "access plus 1 month"
    ExpiresByType image/png      "access plus 1 month"
    ExpiresByType image/webp     "access plus 1 month"
    ExpiresByType image/svg+xml  "access plus 1 week"
    ExpiresByType text/css       "access plus 1 week"
    ExpiresByType text/javascript "access plus 1 week"
</IfModule>

# ── Pages d'erreur ────────────────────────────────────────────────────
ErrorDocument 403 /index.php
ErrorDocument 404 /index.php
